# .env.* 的文件将会依此加载
# BLITZ_PUBLIC_ 开头的参数前端可以访问到
# 使用 blitz xx --env staging,production 时，会自动加载 .env.staging 或 .env.production ， xx 为任何子命令

TIME_ZONE="TIME_ZONE="

# ==== 数据库 ====
# 数据库类型请在 db/schema.prisma 内修改
# 数据库连接例子
# https://www.prisma.io/docs/reference/database-reference/connection-urls#format
DATABASE_URL="file:./db.sqlite"

# Redis 服务相关配置，用来处理登陆权限等。
USE_REDIS="true"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# ==== 站点相关 ====
# 标题
BLITZ_PUBLIC_SITE_TITLE="FDBD"
# 子标题
BLITZ_PUBLIC_SITE_SUB_TITLE="快速数据库设计工具"

# ==== 鉴权相关 ====

# Github 登陆
# 回调地址为 /api/auth/github/callback
AUTH_GITHUB_APPID=""
AUTH_GITHUB_APPSECRET=""

# Gitee 登陆
# 回调地址为 /api/auth/gitee/callback
AUTH_GITEE_APPID=""
AUTH_GITEE_APPSECRET=""

# 微信互联登陆
# 回调地址为 /api/auth/wechat/callback
AUTH_WECHAT_APPID=""
AUTH_WECHAT_APPSECRET=""

# 微信扫码互联登陆，需要公众号
# 回调地址为 /api/auth/wechat_scan/callback
AUTH_WECHAT_SCAN_APPID=""
AUTH_WECHAT_SCAN_APPSECRET=""

# QQ 互联登陆
# 回调地址为 /api/auth/qq/callback
AUTH_QQ_APPID=""
AUTH_QQ_APPSECRET=""
